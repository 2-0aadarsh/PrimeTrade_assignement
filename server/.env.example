PORT=5000
NODE_ENV=development

# Comma-separated browser origins for deployed frontends, e.g.
# CORS_ORIGINS=https://my-app.netlify.app,https://www.my-domain.com
# Local http(s)://localhost, 127.0.0.1, [::1] (any port) are allowed automatically.
CORS_ORIGINS=

MONGO_URI=mongodb://127.0.0.1:27017/primetrade_assignment

JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m

REFRESH_TOKEN_TTL_SECONDS=604800
REFRESH_TOKEN_HASH_SECRET=replace_with_long_random_secret

OTP_HASH_SECRET=replace_with_long_random_secret
EMAIL_OTP_TTL_SECONDS=600
EMAIL_OTP_ATTEMPT_LIMIT=5
EMAIL_OTP_COOLDOWN_SECONDS=60
RESET_TOKEN_TTL_SECONDS=900

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX_REQUESTS=25

SOFT_DELETE_RETENTION_DAYS=60
SOFT_DELETE_CLEANUP_INTERVAL_MS=86400000

EMAIL_SERVICE=gmail
EMAIL_USER=you@example.com
EMAIL_PASSWORD=your_email_app_password
EMAIL_FROM=you@example.com
EMAIL_FROM_NAME=PrimeTrade
EMAIL_BRAND_NAME=PrimeTrade
SUPPORT_EMAIL=support@example.com
DISPLAY_TIMEZONE=Asia/Kolkata
